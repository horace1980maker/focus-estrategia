# Runtime
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://your-domain.example

# SQLite database path (bind this directory to a persistent volume in Coolify)
DATABASE_URL=file:/app/data/prod.db

# Authentication hardening
AUTH_ALLOW_MOCK_FALLBACK=false
AUTH_SESSION_TTL_HOURS=12
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15

# Feature flags
PHASE_WORKSPACES_ENABLED=true
DELIVERABLES_LIFECYCLE_ENABLED=true

# Optional: sync diagnosis submissions to Google Sheets (via Apps Script webhook)
GOOGLE_SHEETS_SYNC_ENABLED=false
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=
GOOGLE_SHEETS_SYNC_TIMEOUT_MS=5000
